meta {
  name: metrics http.client.requests
  type: http
  seq: 9
}

get {
  url: {{actuatorUrl}}/metrics/http.client.requests
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.name: eq http.client.requests
  res.body.availableTags: isArray
  res.body.availableTags: isNotEmpty
  res.body.availableTags[2].tag: isNotEmpty
  res.body.availableTags[2].tag: eq application
  res.body.availableTags[2].values: isArray
  res.body.availableTags[2].values: isNotEmpty
  res.body.availableTags[2].values: contains flug
}

script:pre-request {
  const https = require('node:https');

  const httpsAgent = new https.Agent({
   rejectUnauthorized: false,
  });

  const tokenUrl = bru.getCollectionVar('tokenUrl');
  const username = bru.getEnvVar('username');
  const password = bru.getEnvVar('password');

  const response = await bru.sendRequest({
    method: 'POST',
    url: tokenUrl,
    data: { username, password },
    httpsAgent,
  });
  const token = response.data.access_token;

  const apiUrl = bru.getFolderVar('apiUrl');
  await bru.sendRequest({
    method: 'GET',
    url: `${apiUrl}/00000000-0000-0000-0000-000000000001`,
    headers: {
      Authorization: `Bearer ${token}`,
      Accept: 'application/json',
    },
    httpsAgent,
  });

}

settings {
  encodeUrl: true
  timeout: 0
}
