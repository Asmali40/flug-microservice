meta {
  name: openid-configuration
  type: http
  seq: 1
}

get {
  url: {{realmUrl}}/.well-known/openid-configuration
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.issuer: eq {{realmUrl}}
  res.body.token_endpoint: eq {{oidcTokenUrl}}
}

settings {
  encodeUrl: true
  timeout: 0
}
