meta {
  name: Access Token admin BASIC
  type: http
  seq: 3
}

post {
  url: {{oidcTokenUrl}}
  body: formUrlEncoded
  auth: basic
}

auth:basic {
  username: {{clientId}}
  password: {{clientSecret}}
}

body:form-urlencoded {
  grant_type: password
  username: admin
  password: p
}

assert {
  res.status: eq 200
  res.body.access_token: isString
  res.body.access_token: matches .+\..+\..+
  res.body.expires_in: eq 1800
}

settings {
  encodeUrl: true
  timeout: 0
}
